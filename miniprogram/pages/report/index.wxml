<wxs module="utils">
  function formatDate(ms) {
    var str = getDate(ms + 8 * 60 * 60 * 1000).toISOString()
    var ymd = str.slice(0, 10)
    var hms = str.slice(11, 19)
    return ymd + ' ' + hms
  }
  function approveToText(val) {
    if (val === 'ok') return '审核通过'
    if (val === 'ng') return '审核驳回'
    return '等待审核'
  }
  module.exports = {
    formatDate: formatDate,
    approveToText: approveToText,
  }
</wxs>

<t-cell wx:for="{{titles}}" wx:key="item" title="{{item}}" hover arrow bind:click="onKindClick" mark:index="{{index}}" />
<block wx:if="{{record}}">
  <t-button wx:if="{{!record.publish}}" t-class="tb" block theme="primary" bind:tap="onPublishTap">提交</t-button>
  <view wx:if="{{record.approve==='ok'||record.approve==='ng'}}" class="p">
    <t-cell title="审核人员" note="{{record.approveBy}}" />
    <t-cell title="审核时间" note="{{utils.formatDate(record.approvedAt)}}" />
    <t-cell title="审核结果" note="{{utils.approveToText(record.approve)}}" />
    <t-cell title="审核信息" description="{{record.approveMsg}}" bordered="{{false}}" />
    <view class="z"></view>
  </view>
  <view wx:elif="{{admin.isAdmin}}">
    <view class="k">
      <view>审核结果：</view>
      <t-radio-group t-class="tc" value="{{admin.approve}}" borderless bind:change="onApproveChange">
        <t-radio block="{{false}}" label="通过" value="ok" />
        <t-radio block="{{false}}" label="驳回" value="ng" />
      </t-radio-group>
    </view>
    <t-textarea wx:if="{{admin.approve==='ng'}}" t-class-textarea="tt" placeholder="请输入不合格原因" maxlength="200" indicator value="{{admin.approveMsg}}" bind:change="onApproveMsgChange" />
    <t-button t-class="tb" block theme="primary" bind:tap="onApproveTap">提交</t-button>
    <view class="z"></view>
  </view>
</block>