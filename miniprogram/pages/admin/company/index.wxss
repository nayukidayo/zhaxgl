  align-items: center;
  justify-content: space-between;
}

.f {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  color: var(--td-text-color-secondary);
  font-size: var(--td-font-size-body-small);
}

.l {
  text-align: center;
}

.z {
  height: 20vh;
  padding-top: 20rpx;
  font-size: var(--td-font-size-body-small);
  color: var(--td-text-color-placeholder);
}